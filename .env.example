PORT=4000
HOST=0.0.0.0
NODE_ENV=development
# Internal service key (backward compat for external integrations)
INTERNAL_SERVICE_KEY=dev-internal-key-please-change
# JWT secret — minimum 32 chars, change this!
JWT_SECRET=change-me-jwt-secret-min-32-chars-long
JWT_ACCESS_EXPIRY=8h
# API public URL
API_URL=http://api:4000/api/v1
# Public URL shown in redirect links
PUBLIC_BASE_URL=http://localhost:4000
# Development allows any origin. Production must set explicit origins.
CORS_ORIGIN=*
# First-run admin auto-creation (only runs when no users exist)
ADMIN_SETUP_EMAIL=admin@example.com
ADMIN_SETUP_PASSWORD=change-me-strong-password
# Database (use service name 'db' when running under Docker Compose)
PGHOST=db
PGPORT=5432
PGUSER=rs_user
PGPASSWORD=rs_password
PGDATABASE=redirect_service
PGPOOL_MAX=10
PG_IDLE_TIMEOUT=30000
APP_NAME=Redirect Admin
