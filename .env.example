PORT=4000
HOST=0.0.0.0
NODE_ENV=development
# Internal service key used by WordPress plugin and internal services
INTERNAL_SERVICE_KEY=dev-internal-key-please-change
# API public URL used by the plugin by default (container name 'api' for docker compose)
API_URL=http://api:4000/api/v1
# Public URL shown in WordPress redirect links
PUBLIC_BASE_URL=http://localhost:4000
# Development allows any origin. Production must set explicit origins.
CORS_ORIGIN=*
# Database (use service name 'db' when running under Docker Compose)
PGHOST=db
PGPORT=5432
PGUSER=rs_user
PGPASSWORD=rs_password
PGDATABASE=redirect_service
PGPOOL_MAX=10
PG_IDLE_TIMEOUT=30000
APP_NAME=redirect-service
