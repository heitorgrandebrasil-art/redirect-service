# Production environment example - do NOT commit secrets
PORT=4000
HOST=0.0.0.0
NODE_ENV=production
APP_NAME=redirect-service

# Public API/redirect origin served by Nginx/HTTPS
PUBLIC_BASE_URL=https://redirects.example.com
API_BASE_PATH=/api/v1

# Comma-separated browser origins allowed to call the API.
# Include WordPress origin and redirect origin.
CORS_ORIGIN=https://site.example.com,https://redirects.example.com

INTERNAL_SERVICE_KEY=change-me-to-a-secure-random-value
PGHOST=db
PGPORT=5432
PGUSER=rs_user
PGPASSWORD=change-me-very-strong-password
PGDATABASE=redirect_service
PGPOOL_MAX=10
PG_IDLE_TIMEOUT=30000
TRUST_PROXY=true

# WordPress/plugin integration
API_URL=http://api:4000/api/v1
RDI_API_URL=http://api:4000/api/v1
RDI_PUBLIC_BASE_URL=https://redirects.example.com
RDI_INTERNAL_SERVICE_KEY=change-me-to-a-secure-random-value

# WordPress (if managed in compose)
WP_DB_HOST=wp_db
WP_DB_USER=wp
WP_DB_PASSWORD=strong_wp_password
WP_DB_ROOT_PASSWORD=change-me-root-password
WP_DB_NAME=wordpress
WORDPRESS_URL=https://site.example.com
